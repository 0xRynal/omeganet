{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node10",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"declaration": false,
		"resolveJsonModule": true
	},
	"include": ["bin.ts", "commands/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}

{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": null,
		"rootDirs": ["src", "tests"],
		"outDir": "test-out",
		"incremental": true,
		"tsBuildInfoFile": "node_modules/.cache/omeganet-tests.tsbuildinfo",
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"declaration": false,
		"declarationMap": false
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules", "out", "cli", "examples", "test-out"]
}
